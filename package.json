{
  "name": "tree-sitter-concerto",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Concerto Modelling Language (Accord Project)",
  "repository": {
    "type": "git",
    "url": "https://github.com/accordproject/tree-sitter-concerto"
  },
  "license": "Apache-2.0",
  "author": "Accord Project Contributors",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "concerto",
    "accord-project",
    "cto",
    "modeling-language"
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test && bash test/test-queries.sh",
    "test:corpus": "tree-sitter test",
    "test:queries": "bash test/test-queries.sh",
    "generate": "tree-sitter generate",
    "build": "tree-sitter generate && node-gyp-build",
    "build-wasm": "tree-sitter build --wasm",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.concerto",
      "injection-regex": "^concerto$",
      "file-types": [
        "cto"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ]
}
