{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "concerto",
      "camelcase": "Concerto",
      "scope": "source.concerto",
      "path": ".",
      "file-types": [
        "cto"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "folds": "queries/folds.scm",
      "injection-regex": "^concerto$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Tree-sitter grammar for the Concerto Modelling Language",
    "authors": [
      {
        "name": "Accord Project Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/accordproject/concerto-tree-sitter"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}